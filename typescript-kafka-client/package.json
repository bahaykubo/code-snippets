{
  "name": "kafka-client",
  "version": "1.0.0",
  "main": "./dist/app/main.js",
  "license": "UNLICENSED",
  "scripts": {
    "ci": "rm -rf node_modules && npm ci",
    "lint": "eslint . && prettier --check .",
    "lint-fix": "eslint . --fix && prettier --write . && npm run lint",
    "build": "tsc",
    "test": "mocha",
    "start-dev": "nodemon --ext ts --exec 'npm run build -- --incremental && npm start'",
    "start": "node .",
    "refresh-data": "rm -rf data && ts-node app/utilities/data-seed.ts"
  },
  "dependencies": {
    "dayjs": "^1.11.10",
    "kafkajs": "^2.2.4"
  },
  "devDependencies": {
    "@types/chai": "^4.3.9",
    "@types/mocha": "^10.0.3",
    "@types/node": "^26.0.1",
    "chai": "^4.3.10",
    "eslint-plugin-mocha": "^11.3.0",
    "localtunnel": "^2.0.2",
    "mocha": "^10.2.0",
    "mochawesome": "^7.1.3",
    "nodemon": "^3.0.1",
    "style-lint-js": "^3.0.2",
    "ts-node": "^10.1.0",
    "typescript": "^5.2.2"
  }
}
