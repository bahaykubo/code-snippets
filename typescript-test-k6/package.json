{
  "name": "test-k6",
  "version": "1.0.0",
  "license": "UNLICENSED",
  "scripts": {
    "ci": "rm -rf node_modules && npm ci",
    "lint": "eslint . && prettier --check .",
    "lint-fix": "eslint . --fix && prettier --write . && npm run lint",
    "build": "webpack",
    "test": "mkdir reports -p && npm run build && UID_GID=$(id -u):$(id -g) docker compose up && docker compose down",
    "test-local": "npm run build && k6 run --summary-export=reports/report.json"
  },
  "devDependencies": {
    "@babel/core": "^7.18.9",
    "@babel/preset-env": "^7.18.9",
    "@babel/preset-typescript": "^7.18.6",
    "@types/k6": "^0.47.2",
    "@types/node": "^26.0.1",
    "babel-loader": "^9.1.3",
    "clean-webpack-plugin": "^4.0.0",
    "copy-webpack-plugin": "^11.0.0",
    "core-js": "^3.24.0",
    "style-lint-js": "^3.0.2",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.2",
    "webpack": "^5.74.0",
    "webpack-cli": "^5.1.4",
    "webpack-glob-entries": "^1.0.1"
  }
}
