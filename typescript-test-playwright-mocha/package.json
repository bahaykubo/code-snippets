{
  "name": "test-playwright-mocha-ts",
  "description": "testing with playwright and mocha in typescript",
  "version": "1.0.0",
  "author": "noel sevilla",
  "license": "UNLICENSED",
  "scripts": {
    "ci": "rm -fr node_modules && npm ci",
    "lint": "eslint . && prettier --check .",
    "lint-fix": "eslint . --fix && prettier --write . && npm run lint",
    "test": "mocha",
    "test-ui": "HEADLESS=false mocha --require ./services/utilities/test-hooks.ts",
    "test-ui-parallel": "npm run test-ui -- --parallel",
    "test-ui-headless": "mocha --require ./services/utilities/test-hooks.ts",
    "test-ui-headless-parallel": "npm run test-ui-headless -- --parallel",
    "test-ui-watch": "npm run test-ui -- --watch",
    "test-api": "npm test -- ./tests/api/**/*.test.ts",
    "test-api-parallel": "npm run test-api -- --parallel"
  },
  "devDependencies": {
    "@types/chai": "^4.3.10",
    "@types/mocha": "^10.0.4",
    "@types/node": "^26.0.1",
    "axios": "^1.6.1",
    "chai": "^4.3.10",
    "dotenv": "^16.3.1",
    "eslint-plugin-mocha": "^11.3.0",
    "mocha": "^10.2.0",
    "mochawesome": "7.1.3",
    "playwright": "1.39.0",
    "style-lint-js": "^3.0.2",
    "ts-node": "^10.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.2.2"
  }
}
