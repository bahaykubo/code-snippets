{
  "name": "test-playwright",
  "description": "testing with playwright and playwright test runner",
  "version": "1.0.0",
  "author": "noel sevilla",
  "license": "UNLICENSED",
  "scripts": {
    "ci": "rm -fr node_modules && npm ci",
    "lint": "eslint . && prettier --check .",
    "lint-fix": "eslint . --fix && prettier --write . && npm run lint",
    "test": "playwright test",
    "test-ui": "playwright test --project=ui",
    "test-api": "playwright test --project=api",
    "open-html-report": "playwright show-report artifacts/html"
  },
  "devDependencies": {
    "@playwright/test": "1.39.0",
    "@types/node": "20.9.0",
    "dotenv": "16.3.1",
    "eslint-plugin-playwright": "^2.0.0",
    "playwright": "1.39.0",
    "style-lint-js": "^3.0.2",
    "ts-node": "10.9.1",
    "typescript": "5.2.2"
  }
}
